generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Sexo {
  MACHO
  HEMBRA
}

enum TipoCuidado {
  VACUNA
  DESPARASITACION
  REVISION
  OTRO
}

model Perro {
  id              String    @id @default(uuid())
  usuarioId       String
  nombre          String
  raza            String
  fechaNacimiento DateTime?
  sexo            Sexo?
  peso            Decimal?  @db.Decimal(5, 2)
  notas           String?
  fotoPath        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cuidados Cuidado[]
  tareas   Tarea[]

  @@index([usuarioId])
}

model Cuidado {
  id         String      @id @default(uuid())
  usuarioId  String
  perroId    String
  tipo       TipoCuidado
  tipoLibre  String?
  fecha      DateTime
  notas      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  perro Perro @relation(fields: [perroId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([perroId])
}

model Tarea {
  id        String   @id @default(uuid())
  usuarioId String
  perroId   String
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  perro       Perro             @relation(fields: [perroId], references: [id], onDelete: Cascade)
  completadas TareaCompletada[]

  @@index([usuarioId])
  @@index([perroId])
}

model TareaCompletada {
  id        String   @id @default(uuid())
  tareaId   String
  fecha     DateTime @db.Date
  createdAt DateTime @default(now())

  tarea Tarea @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@unique([tareaId, fecha])
}
